{
  "name": "@eslint-zod/utils",
  "version": "1.2.0",
  "description": "Shared utilities for eslint-zod plugins",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "utils",
    "zod"
  ],
  "homepage": "https://github.com/marcalexiei/eslint-zod#readme",
  "bugs": {
    "url": "https://github.com/marcalexiei/eslint-zod/issues"
  },
  "license": "MIT",
  "author": "Marco Pasqualetti @marcalexiei",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcalexiei/eslint-zod",
    "directory": "packages/utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@eslint-zod/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest"
  },
  "dependencies": {
    "@typescript-eslint/utils": "catalog:deps"
  },
  "devDependencies": {
    "tsdown": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "engines": {
    "node": "^20 || ^22 || >=24"
  }
}
